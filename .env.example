# ──────────────────────────────────────────────────────────────
# Square configuration — copy to .env.local and fill in.
# Use SANDBOX values for development; PRODUCTION values go in the
# host's env vars (e.g. Vercel), never in git.
# ──────────────────────────────────────────────────────────────

# Server-side only (secret)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox            # sandbox | production
SQUARE_LOCATION_ID=

# Webhook signature key (Square Dashboard → Webhooks → your subscription)
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Public (shipped to the browser via NEXT_PUBLIC_*)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
