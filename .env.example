# Square credentials (server-side only — NEVER prefix with VITE_, or it leaks into the client bundle)
SQUARE_ACCESS_TOKEN=your_square_access_token_here

# Square API base. Use the sandbox URL while testing, the production URL when live.
# Sandbox:    https://connect.squareupsandbox.com
# Production:  https://connect.squareup.com
SQUARE_API_BASE=https://connect.squareupsandbox.com

# Optional: where Contact / Join-Team forms POST to (e.g. a GHL webhook or CRM endpoint).
# If left empty, forms validate and confirm locally without sending anywhere.
VITE_FORM_ENDPOINT=
